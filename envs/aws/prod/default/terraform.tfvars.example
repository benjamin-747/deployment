base_domain = "gitmega.com"
region      = "ap-southeast-2"
db_username = "gitmega"
db_password = "db_password"
db_schema   = "gitmega"

s3_key        = "s3_key"
s3_secret_key = "s3_secret"
s3_bucket     = "gitmega"

rails_master_key = "ask admin for rails key"
rails_env        = "staging-gitmega"
ui_env           = "gitmega"
app_suffix       = "gitmega-com"

# Optional: if empty, defaults to latest Ubuntu 24.04 (glibc 2.39+)
ec2_ami          = ""
ec2_instance_type = "t3.micro"
